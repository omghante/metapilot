# ============================================================
# MetaPilot API — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Django Core ──────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://metapilot:password@localhost:5432/metapilot

# ── Redis ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CHANNEL_REDIS_URL=redis://localhost:6379/1

# ── Encryption ───────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Meta / WhatsApp ──────────────────────────────────────────
META_GRAPH_API_VERSION=v22.0
WEBHOOK_BASE_URL=https://your-domain.com

# ── AI / OpenRouter ──────────────────────────────────────────
OPENROUTER_API_KEY=
WA_CHATBOT_ENABLED=True
WA_CHATBOT_TEXT_MODEL=stepfun/step-3.5-flash
WA_CHATBOT_VISION_MODEL=openai/gpt-4o
WA_CHATBOT_MAX_HISTORY=15
WA_CHATBOT_FALLBACK_MESSAGE=Thank you! Our team will get back to you shortly.

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Scheduler ────────────────────────────────────────────────
SCHEDULER_BATCH_SIZE=20
SCHEDULER_RATE_LIMIT_TOKENS=50
SERVER_ID=server_01

# ── Observability (optional) ─────────────────────────────────
SENTRY_DSN=
